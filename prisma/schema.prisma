generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Vendor {
  id           String   @id @default(cuid())
  slug         String   @unique
  name         String
  email        String   @unique
  passwordHash String
  bio          String?
  city         String   @default("New York")
  avatarUrl    String?
  // Stripe Connect structure only — no live keys yet.
  stripeAccountId String?
  createdAt    DateTime @default(now())

  collections  Collection[]
  products     Product[]
  orders       Order[]
}

model Collection {
  id          String   @id @default(cuid())
  vendorId    String
  vendor      Vendor   @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  slug        String
  name        String
  description String?
  season      String? // e.g. "Verano", "Otoño", "Sport", "Formal" — free text tag
  createdAt   DateTime @default(now())

  products    Product[]

  @@unique([vendorId, slug])
}

model Product {
  id                  String   @id @default(cuid())
  slug                String   @unique
  vendorId            String
  vendor              Vendor   @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  collectionId        String?
  collection          Collection? @relation(fields: [collectionId], references: [id], onDelete: SetNull)
  name                String
  description         String
  videoUrl            String?
  priceCents          Int
  compareAtPriceCents Int?
  sellItemsSeparately Boolean  @default(false)
  status              String   @default("published") // draft | published
  // Stripe structure only — no live keys yet.
  stripePriceId       String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  images     ProductImage[]
  items      ProductItem[]
  orderItems OrderItem[]
}

model ProductImage {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  url       String
  position  Int     @default(0)
}

model ProductItem {
  id          String   @id @default(cuid())
  productId   String
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  name        String
  description String?
  priceCents  Int
  imageUrl    String?
  sizes       String   @default("[]") // JSON array of strings
  position    Int      @default(0)
  createdAt   DateTime @default(now())

  orderItems  OrderItem[]
}

model Order {
  id                     String   @id @default(cuid())
  vendorId               String
  vendor                 Vendor   @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  customerName           String
  email                  String
  phone                  String?
  address                String
  city                   String
  notes                  String?
  subtotalCents          Int
  status                 String   @default("pending_payment")
  // Stripe structure only — no live keys yet.
  stripePaymentIntentId  String?
  createdAt              DateTime @default(now())

  items OrderItem[]
}

model OrderItem {
  id            String       @id @default(cuid())
  orderId       String
  order         Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId     String?
  product       Product?     @relation(fields: [productId], references: [id], onDelete: SetNull)
  productItemId String?
  productItem   ProductItem? @relation(fields: [productItemId], references: [id], onDelete: SetNull)
  name          String
  kind          String // "set" | "item"
  size          String?
  qty           Int
  priceCents    Int
}
